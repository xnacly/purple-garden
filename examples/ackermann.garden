# Ackermann function; classic explosive recursion.
# Stresses call/return, caller-save spill, and arg shuffles.
# ack(3, 8) = 2045, ack(3, 9) = 4093.
import "testing"

#! Compute the Ackermann function for small inputs.
fn ack(m:Int n:Int) Int {
    match {
        m == 0 { n + 1 }
        n == 0 { ack(m-1 1) }
        { ack(m-1 ack(m n-1)) }
    }
}
testing.assert(ack(3 8) == 2045)
